# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=your_bot_username

# Admin Telegram IDs (comma-separated)
ADMIN_IDS=123456789,987654321

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/himoya
DATABASE_SYNC_URL=postgresql+psycopg://USER:PASSWORD@localhost:5432/himoya

# Redis (optional, for FSM. Empty = MemoryStorage)
REDIS_URL=

# Environment: development | production
ENVIRONMENT=development

# Logging level
LOG_LEVEL=INFO

# Encryption key for anonymous reports
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Rate limiting
RATE_LIMIT_SECONDS=300

# Default language: uz | ru | en
DEFAULT_LANGUAGE=uz
